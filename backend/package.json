{
  "name": "validateur-backend",
  "version": "1.0.0",
  "description": "API de validation de tickets et cartes prépayées",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "npx prisma migrate dev",
    "migrate:prod": "npx prisma migrate deploy",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "npx prisma studio",
    "lint": "eslint src --ext .ts",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.1",
    "@prisma/client": "^5.7.1",
    "nodemailer": "^6.9.7",
    "node-cron": "^3.0.3",
    "csv-parser": "^3.0.0",
    "xlsx": "^0.18.5",
    "winston": "^3.11.0",
    "express-validator": "^7.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.14",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.7.1",
    "@eslint/js": "^8.56.0",
    "eslint": "^8.56.0",
    "typescript-eslint": "^6.17.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  }
